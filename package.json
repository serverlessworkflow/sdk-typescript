{
  "name": "@serverlessworkflow/sdk",
  "version": "1.0.2-alpha1",
  "schemaVersion": "1.0.0",
  "description": "Typescript SDK for Serverless Workflow Specification",
  "main": "./cjs/index.cjs",
  "browser": "./umd/index.umd.min.js",
  "module": "./esm/index.js",
  "types": "./index.d.ts",
  "typings": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./esm/index.js",
      "require": "./cjs/index.cjs",
      "default": "./esm/index.js"
    },
    "./package.json": "./package.json",
    "./umd/*": "./umd/*"
  },
  "files": [
    "cjs",
    "esm",
    "umd",
    "lib",
    "index.d.ts",
    "index.d.ts.map",
    "serverless-workflow-sdk.d.ts",
    "serverless-workflow-sdk.d.ts.map",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "sideEffects": false,
  "packageManager": "npm@11.5.1",
  "scripts": {
    "rimraf": "npx rimraf",
    "shx": "npx shx",
    "tsc": "npx tsc",
    "ts-node": "npx ts-node",
    "eslint": "npx eslint",
    "prettier": "npx prettier",
    "lint-staged": "npx lint-staged",
    "clean": "npx rimraf dist out-tsc",
    "tools:1_download-schemas": "npx ts-node --project ./tools/tsconfig.json ./tools/1_download-schemas.ts",
    "tools:2_generate-definitions": "npx ts-node --project ./tools/tsconfig.json ./tools/2_generate-definitions.ts",
    "tools:3_generate-validation-pointers": "npx ts-node --project ./tools/tsconfig.json ./tools/3_generate-validation-pointers.ts",
    "tools:4_generate-classes": "npx ts-node --project ./tools/tsconfig.json ./tools/4_generate-classes.ts",
    "tools:5_generate-builders": "npx ts-node --project ./tools/tsconfig.json ./tools/5_generate-builders.ts",
    "codegen": "npm run tools:1_download-schemas && npm run tools:2_generate-definitions && npm run tools:3_generate-validation-pointers && npm run tools:4_generate-classes && npm run tools:5_generate-builders && npm run format",
    "codegen:check": "npm run codegen && git diff --exit-code -- src/lib/generated",
    "update-code-base": "npm run codegen && npm run test",
    "format": "npx prettier --write .",
    "format:check": "npx prettier --check .",
    "lint": "npx eslint . && npm run format:check",
    "typecheck": "npx tsc --project ./tsconfig.typecheck.json --noEmit",
    "pretest": "npx rimraf out-tsc",
    "test": "npm run typecheck && npx tsc --project ./tests/tsconfig.json && npx jest",
    "build": "npm run clean && npx rollup -c rollup.config.ts && npx shx mv ./dist/src/lib ./dist/lib && npx shx mv ./dist/src/*.d.ts.map ./dist/src/*.d.ts ./dist && npx rimraf ./dist/src && node ./scripts/prepare-dist-package.mjs",
    "validate:dist-manifest": "node ./scripts/validate-dist-manifest.mjs",
    "verify-publish-directory": "node ./scripts/verify-publish-directory.mjs",
    "prepack": "npm run verify-publish-directory",
    "prepublishOnly": "npm run verify-publish-directory",
    "pack:dist": "node ./scripts/cleanup-tarballs.mjs && npm pack ./dist --cache ./.npm-cache",
    "validate:tarball": "node ./scripts/validate-tarball.mjs",
    "validate:package": "npm run build && npm run validate:dist-manifest && npm run pack:dist && npm run validate:tarball",
    "prepare": "husky",
    "serve": "npm run build && npx http-server -c-1 -o /examples/browser"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@apidevtools/json-schema-ref-parser": "^11.6.4",
    "@rollup/plugin-commonjs": "^26.0.1",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@types/jest": "^29.5.12",
    "@types/js-yaml": "^4.0.9",
    "@types/yargs": "^17.0.32",
    "@typescript-eslint/eslint-plugin": "^7.16.1",
    "@typescript-eslint/parser": "^7.16.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "http-server": "^14.1.1",
    "husky": "^9.0.11",
    "jest": "^29.7.0",
    "json-schema-to-typescript": "^15.0.2",
    "lint-staged": "^15.2.7",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "rollup": "^2.79.1",
    "rollup-plugin-sourcemaps": "^0.6.3",
    "rollup-plugin-typescript2": "^0.36.0",
    "shx": "^0.3.4",
    "ts-inference-check": "^0.3.0",
    "ts-jest": "^29.2.2",
    "ts-morph": "^23.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.3",
    "yargs": "^17.7.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/serverlessworkflow/sdk-typescript.git"
  },
  "author": {
    "name": "Serverless Workflow Contributors",
    "url": "https://serverlessworkflow.io"
  },
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/serverlessworkflow/sdk-typescript/issues"
  },
  "homepage": "https://serverlessworkflow.io",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  }
}
